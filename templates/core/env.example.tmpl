# Strata template — rendered by /strata:init and /strata:adopt into the project .env.example.
#
# Rules (PROJECT_PATTERN §6):
#   - Commit .env.example; NEVER commit the real .env (it is gitignored).
#   - Copy this file:  cp .env.example .env   and fill in real values.
#   - chmod 600 .env   on any production host.
#   - Comments use '#' ONLY. Do NOT use '//' (the docker env_file parser breaks on it).
#   - Every variable is prefixed with the service name ({{SERVICE_PREFIX}}_) so multiple
#     services sharing one host stay isolated.

# --- Core service config ---
{{SERVICE_PREFIX}}_ENV=development            # development | staging | production
{{SERVICE_PREFIX}}_LOG_LEVEL=INFO
{{SERVICE_PREFIX}}_PORT=8000

# --- Database (read-only user until a write-path is ADR'd) ---
{{SERVICE_PREFIX}}_DB_HOST=localhost
{{SERVICE_PREFIX}}_DB_PORT=5432
{{SERVICE_PREFIX}}_DB_NAME={{SERVICE_SLUG}}
{{SERVICE_PREFIX}}_DB_USER=changeme
{{SERVICE_PREFIX}}_DB_PASS=changeme           # real value only in .env, never here

# --- External APIs / secrets (placeholders only) ---
{{SERVICE_PREFIX}}_API_KEY=changeme
# {{SERVICE_PREFIX}}_OPENAI_API_KEY=sk-...     # uncomment if used
